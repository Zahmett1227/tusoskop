{
  "name": "tusoskop",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --configLoader native",
    "build": "vite build --configLoader native",
    "lint": "eslint .",
    "test": "vitest run --configLoader native",
    "test:rules": "firebase emulators:exec --only firestore \"node scripts/firestore-rules-emulator-test.mjs\"",
    "validate:questions": "node scripts/validate-question-bank.mjs",
    "audit:questions": "node scripts/audit-question-bank-quality.mjs",
    "review:questions": "node scripts/build-question-review-queue.mjs",
    "check:incoming": "node scripts/check-incoming-questions.mjs",
    "quality:questions": "npm run validate:questions && npm run audit:questions && npm run review:questions",
    "test:social-visuals": "node scripts/test-social-visuals.mjs",
    "test:e2e": "playwright test",
    "test:e2e:full": "npm run build && npm run test:e2e",
    "cap:sync:ios": "npm run build && cap sync ios",
    "cap:open:ios": "cap open ios",
    "preview": "vite preview --configLoader native"
  },
  "dependencies": {
    "@capacitor-firebase/authentication": "^8.2.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@capacitor/ios": "^8.3.4",
    "@capacitor/keyboard": "^8.0.3",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@microsoft/clarity": "^1.0.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "chart.js": "^4.5.1",
    "firebase": "^12.12.0",
    "firebase-admin": "^14.0.0",
    "react": "^19.2.4",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "firebase-admin": "^14.0.0",
    "globals": "^17.4.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.9",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.1",
    "vitest": "^4.1.5"
  }
}
