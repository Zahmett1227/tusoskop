# --- İstemciye enjekte edilen değişkenler (VITE_ öneki zorunlu) ---

# Microsoft Clarity proje ID’si. Boş bırakılırsa Clarity snippet üretilmez.
VITE_CLARITY_PROJECT_ID=

# Shopify Checkout URL’leri (Plus planları — src/config/plusPlans.js)
VITE_SHOPIFY_PLUS_1M_URL=
VITE_SHOPIFY_PLUS_3M_URL=
VITE_SHOPIFY_PLUS_6M_URL=

# --- Firebase ---
# Web SDK yapılandırması şu an kaynakta: src/firebase.js
# İsterseniz buraya yer tutucu notları ekleyip projeyi VITE_FIREBASE_* ile taşıyabilirsiniz (şu an kullanılmıyor).
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_MEASUREMENT_ID=

# --- Instagram Graph API (YALNIZCA Cloud Functions — frontend'e koymayın) ---
# Resmi Meta Business / Content Publishing API
# META_APP_ID=
# META_APP_SECRET=
# META_PAGE_ID=
# INSTAGRAM_BUSINESS_ACCOUNT_ID=
# META_ACCESS_TOKEN=
