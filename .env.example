# --- İstemciye enjekte edilen değişkenler (VITE_ öneki zorunlu) ---

# Microsoft Clarity proje ID’si. Boş bırakılırsa Clarity snippet üretilmez.
VITE_CLARITY_PROJECT_ID=

# --- Kampanya /basla yönlendirme (Vercel serverless) ---
# App Store Connect campaign provider token. Boşsa TR fallback App Store URL kullanılır.
APPLE_CAMPAIGN_PT=

# Firebase Admin SDK service account JSON (tek satır). Vercel Production/Preview env.
# Repoya ASLA commit etmeyin. Örnek: Firebase Console → Project settings → Service accounts → Generate new private key
# Vercel'de FIREBASE_SERVICE_ACCOUNT_JSON adıyla tüm JSON'u tek satır yapıştırın.
FIREBASE_SERVICE_ACCOUNT_JSON=

# --- PayTR iFrame API (YALNIZCA Cloud Functions — frontend'e koymayın) ---
# Mağaza No gizli değildir; key ve salt Secret Manager'da tutulmalı.
# Deploy öncesi (functions klasöründe):
#   firebase functions:secrets:set PAYTR_MERCHANT_KEY
#   firebase functions:secrets:set PAYTR_MERCHANT_SALT
# PAYTR_MERCHANT_ID Cloud Functions ortam değişkeni (varsayılan: 699560)
# PAYTR_MERCHANT_ID=699560
# Test modu (gerçek çekim yapmaz): PAYTR_TEST_MODE=1
# PAYTR_TEST_MODE=0
#
# PayTR panelinde "Bildirim URL" olarak şunu tanımlayın:
#   https://us-central1-tusoskop.cloudfunctions.net/paytrCallback

# --- Firebase ---
# Web SDK yapılandırması şu an kaynakta: src/firebase.js
# İsterseniz buraya yer tutucu notları ekleyip projeyi VITE_FIREBASE_* ile taşıyabilirsiniz (şu an kullanılmıyor).
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_MEASUREMENT_ID=

# --- Instagram Graph API (YALNIZCA Cloud Functions — frontend'e koymayın) ---
# Resmi Meta Business / Content Publishing API
# META_APP_ID=
# META_APP_SECRET=
# META_PAGE_ID=
# INSTAGRAM_BUSINESS_ACCOUNT_ID=
# META_ACCESS_TOKEN=
