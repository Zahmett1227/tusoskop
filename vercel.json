  "rewrites": [
    {
      "source": "/basla",
      "destination": "/api/campaign-redirect"
    },
    {
      "source": "/basla/",
      "destination": "/api/campaign-redirect"
    },
    {
      "source": "/başla",
      "destination": "/api/campaign-redirect"
    },
    {
      "source": "/ba%C5%9Fla",
