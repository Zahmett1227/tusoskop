{
  "redirects": [
    {
      "source": "/indir",
      "destination": "https://apps.apple.com/tr/app/tusoskop/id6776331691?l=tr",
      "permanent": true
    },
    {
      "source": "/tusoskop-fiyatlandirma",
      "destination": "/fiyatlandirma",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "tusoskop.com" }],
      "destination": "https://www.tusoskop.com/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/giris",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, follow" }]
    },
    {
      "source": "/app",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, follow" }]
    },
    {
      "source": "/app/(.*)",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, follow" }]
    }
  ],
  "rewrites": [
    {
      "source": "/basla",
      "destination": "/api/campaign-redirect"
    },
    {
      "source": "/basla/",
      "destination": "/api/campaign-redirect"
    },
    {
      "source": "/başla",
      "destination": "/api/campaign-redirect"
    },
    {
      "source": "/ba%C5%9Fla",
      "destination": "/api/campaign-redirect"
    },
    {
      "source": "/coz/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
