# Firebase — Tusoskop ile AYNI proje. Değerleri Firebase Console →
# Proje Ayarları → Web uygulaması config'inden al. Tümü boş bırakılırsa
# uygulama anonim (localStorage) modda çalışır; istatistik buluta yedeklenmez.
#
# Vercel'de bu değerler Project Settings → Environment Variables altına eklenir.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
