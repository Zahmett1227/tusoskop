rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.active == true;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function hasOnlySafeSelfCreatePremiumValues() {
      return request.resource.data.plan == 'free'
        && request.resource.data.premiumStatus == 'inactive'
        && request.resource.data.premiumSource == 'none'
        && request.resource.data.premiumUntil == null
        && request.resource.data.lifetimePremium == false
        && request.resource.data.adminNote == null
        && request.resource.data.grantedBy == null
        && request.resource.data.grantedAt == null;
    }

    function hasRequiredSelfCreatePremiumKeys() {
      return request.resource.data.keys().hasAll([
        'plan',
        'premiumStatus',
        'premiumSource',
        'premiumUntil',
        'lifetimePremium'
      ]);
    }

    function hasValidAcquisitionShape(data) {
      return data.keys().hasOnly(['source', 'medium', 'campaign', 'firstSeenAt'])
        && data.source is string
        && data.source.size() > 0
        && data.source.size() <= 50
        && data.medium is string
        && data.medium.size() > 0
        && data.medium.size() <= 30
        && data.campaign is string
        && data.campaign.size() > 0
        && data.campaign.size() <= 40
        && data.firstSeenAt is timestamp;
    }

    function hasOptionalValidAcquisitionOnCreate() {
      return !request.resource.data.keys().hasAny(['acquisition'])
        || hasValidAcquisitionShape(request.resource.data.acquisition);
    }

    function userHasAcquisition() {
      return resource.data.keys().hasAny(['acquisition'])
        && resource.data.acquisition != null;
    }

    function isSafeAcquisitionUpdate() {
      return !userHasAcquisition()
        && request.resource.data.keys().hasAny(['acquisition'])
        && hasValidAcquisitionShape(request.resource.data.acquisition)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'acquisition',
          'updatedAt',
          'lastLoginAt',
          'lastSeenAt',
          'platform',
          'appVersion',
          'email',
          'displayName',
          'photoURL'
        ]);
    }

    function hasAllowedSelfUserCreateKeys() {
      return request.resource.data.keys().hasOnly([
        'uid',
        'email',
        'displayName',
        'photoURL',
        'plan',
        'premiumStatus',
        'premiumSource',
        'premiumUntil',
        'lifetimePremium',
        'adminNote',
        'grantedBy',
        'grantedAt',
        'platform',
        'appVersion',
        'createdAt',
        'updatedAt',
        'lastLoginAt',
        'lastSeenAt',
        'acquisition'
      ]);
    }

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid)
        && request.resource.data.uid == request.auth.uid
        && hasAllowedSelfUserCreateKeys()
        && hasRequiredSelfCreatePremiumKeys()
        && hasOnlySafeSelfCreatePremiumValues()
        && hasOptionalValidAcquisitionOnCreate();
      allow update: if isAdmin()
        || isSafeAcquisitionUpdate()
        || (
          isOwner(uid)
          && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny([
              'plan',
              'premiumStatus',
              'premiumSource',
              'premiumUntil',
              'lifetimePremium',
              'adminNote',
              'grantedBy',
              'grantedAt',
              'role',
              'isAdmin',
              'admin',
              'acquisition'
            ])
        );
    }

    match /admins/{uid} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /adminLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    match /streaks/{uid} {
      allow read, write: if isOwner(uid);
    }

    match /studyCollections/{uid}/{document=**} {
      allow read, write: if isOwner(uid);
    }

    match /examResults/{uid}/{document=**} {
      allow read, write: if isOwner(uid);
    }

    // Usage sayaçları yalnızca Cloud Functions (Admin SDK) ile yazar; istemci manipülasyonu engellenir.
    match /users/{uid}/usage/{usageId} {
      allow read: if isOwner(uid) || isAdmin();
      allow create, update, delete: if false;
    }

    match /users/{uid}/wrongQuestions/{questionId} {
      allow read, write: if isOwner(uid) || isAdmin();
    }

    match /users/{uid}/favoriteQuestions/{questionId} {
      allow read, write: if isOwner(uid) || isAdmin();
    }

    match /users/{uid}/smartReviews/{questionId} {
      allow read, write: if isOwner(uid) || isAdmin();
    }

    match /users/{uid}/fsrsAddEvents/{eventId} {
      allow read, create: if isOwner(uid);
      allow update, delete: if false;
    }

    match /users/{uid}/fsrsDailyStats/{statDate} {
      allow read, create, update: if isOwner(uid);
      allow delete: if false;
    }

    // AI günlük önerileri yalnızca backend (Admin SDK) tarafından yazılır; istemci sadece okuyabilir.
    match /users/{uid}/aiRecommendations/{recDate} {
      allow read: if isOwner(uid);
      allow create, update, delete: if false;
    }


    match /users/{uid}/questionHistory/{questionId} {
      allow read: if isOwner(uid) || isAdmin();
      allow create, update: if (isOwner(uid) || isAdmin())
        && request.resource.data.questionId == int(questionId);
      allow delete: if isAdmin();
    }

    match /results/{resultId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update, delete: if false;
    }

    match /studySessions/{sessionId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update, delete: if false;
    }

    // purchaseIntentService.js create payload ile hizalı; admin/aktivasyon alanları yalnızca admin update.
    function hasForbiddenPremiumPurchaseIntentCreateKeys() {
      return request.resource.data.keys().hasAny([
        'activated',
        'activatedAt',
        'activatedBy',
        'activatedForUid',
        'grantedAt',
        'grantedBy',
        'grantedUntil',
        'premiumUntil',
        'lifetimePremium',
        'premiumStatus',
        'premiumSource',
        'plan',
        'paidAt',
        'paymentStatus',
        'orderId',
        'paytrOrderId',
        'reviewedAt',
        'reviewedBy',
        'updatedAt',
        'userId',
        'displayName',
        'amount',
        'source',
        'userAgent'
      ]);
    }

    function isSafePremiumPurchaseIntentCreate() {
      let data = request.resource.data;
      return !hasForbiddenPremiumPurchaseIntentCreateKeys()
        && data.keys().hasOnly([
          'uid',
          'email',
          'planId',
          'planLabel',
          'planSku',
          'durationDays',
          'monthlyPrice',
          'monthlyPriceLabel',
          'totalPrice',
          'totalPriceLabel',
          'currency',
          'provider',
          'status',
          'shopifyUrlConfigured',
          'shopifyOrderName',
          'shopifyOrderId',
          'paymentCheckedAt',
          'paymentCheckedBy',
          'adminNote',
          'createdAt'
        ])
        && data.uid == request.auth.uid
        && data.status == 'started'
        && data.shopifyOrderName == null
        && data.shopifyOrderId == null
        && data.paymentCheckedAt == null
        && data.paymentCheckedBy == null
        && data.adminNote == null;
    }

    match /premiumPurchaseIntents/{intentId} {
      allow create: if isSignedIn() && isSafePremiumPurchaseIntentCreate();
      allow read, update: if isAdmin();
      allow delete: if false;
    }

    // IAP abonelik → hesap bağı. Yalnızca Cloud Functions (Admin SDK) yazar/okur;
    // istemci erişimi tamamen kapalı (savunma derinliği).
    match /appleSubscriptions/{originalTransactionId} {
      allow read, write: if false;
    }

    // Nickname benzersizlik tablo — okuma herkes, yazma transaction ile kendi kaydı
    match /normalizedNicknames/{normalized} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid;
      allow delete: if isSignedIn()
        && resource.data.uid == request.auth.uid;
      allow update: if false;
    }

    // Leaderboard profilleri — nickname, isOptedIn vs.
    function isValidLeaderboardNickname(nick) {
      return nick is string
        && nick.size() >= 3
        && nick.size() <= 20;
    }

    match /leaderboardProfiles/{uid} {
      allow read: if true;
      allow create: if isOwner(uid)
        && request.resource.data.uid == uid
        && isValidLeaderboardNickname(request.resource.data.nickname)
        && request.resource.data.keys().hasOnly([
          'uid', 'nickname', 'normalizedNickname', 'isOptedIn',
          'createdAt', 'updatedAt', 'lastNicknameChangeAt'
        ]);
      allow update: if isOwner(uid)
        && isValidLeaderboardNickname(request.resource.data.nickname)
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['uid', 'createdAt']);
      allow delete: if false;
    }

    // Haftalık sıralama — kullanıcı kendi skorunu yazar, herkes okur
    match /weeklyLeaderboard/{weekId}/users/{uid} {
      allow read: if true;
      allow create, update: if isOwner(uid);
      allow delete: if false;
    }

    // Soru deduplicate — kullanıcı kendi çözüm kaydını ekler, silemez
    match /weeklyLeaderboard/{weekId}/users/{uid}/solvedQuestions/{questionId} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid);
      allow update, delete: if false;
    }

    // Günlük bonus deduplicate — kullanıcı kendi event'ini ekler, silemez
    match /weeklyLeaderboard/{weekId}/users/{uid}/dailyEvents/{eventId} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid);
      allow update, delete: if false;
    }

    // Sosyal medya içerik kuyruğu — yalnızca admin
    match /socialContentQueue/{contentId} {
      allow read, create, update: if isAdmin();
      allow delete: if false;
    }

    match /socialLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    // Instagram /basla kampanya tıklamaları — yalnızca backend (Admin SDK) yazar.
    match /campaignClicks/{clickId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }
  }
}
