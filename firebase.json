{
  "firestore": {
    "rules": "firestore.rules",
    "predeploy": ["node ./scripts/check-backend-integrity.mjs rules"]
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "predeploy": ["node ./scripts/check-backend-integrity.mjs functions"],
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ],
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "redirects": [
      {
        "source": "/indir",
        "destination": "https://apps.apple.com/tr/app/tusoskop/id6776331691?l=tr",
        "type": 301
      },
      {
        "source": "/tusoskop-fiyatlandirma",
        "destination": "/fiyatlandirma",
        "type": 301
      }
    ],
    "headers": [
      {
        "source": "/giris",
        "headers": [{ "key": "X-Robots-Tag", "value": "noindex, follow" }]
      },
      {
        "source": "/app",
        "headers": [{ "key": "X-Robots-Tag", "value": "noindex, follow" }]
      },
      {
        "source": "/app/**",
        "headers": [{ "key": "X-Robots-Tag", "value": "noindex, follow" }]
      }
    ],
    "rewrites": [
      {
        "source": "/basla",
        "destination": "/basla.html"
      },
      {
        "source": "/basla/**",
        "destination": "/basla.html"
      },
      {
        "source": "/başla",
        "destination": "/basla.html"
      },
      {
        "source": "/ba%C5%9Fla",
        "destination": "/basla.html"
      },
      {
        "source": "/coz/**",
        "destination": "/index.html"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
